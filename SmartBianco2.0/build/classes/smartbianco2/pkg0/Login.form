                <AuxValue name="JavaCodeGenerator_CreateCodeCustom" type="java.lang.String" value="new javax.swing.JLabel() {&#xd;&#xa;    @Override&#xd;&#xa;    protected void paintComponent(java.awt.Graphics g) {&#xd;&#xa;        // Ativa uma renderiza&#xe7;&#xe3;o mais bonita (anti-aliasing) para o &#xed;cone n&#xe3;o ficar pixelado&#xd;&#xa;        java.awt.Graphics2D g2 = (java.awt.Graphics2D) g;&#xd;&#xa;        g2.setRenderingHint(java.awt.RenderingHints.KEY_ANTIALIASING, java.awt.RenderingHints.VALUE_ANTIALIAS_ON);&#xd;&#xa;        g2.setRenderingHint(java.awt.RenderingHints.KEY_INTERPOLATION, java.awt.RenderingHints.VALUE_INTERPOLATION_BILINEAR);&#xd;&#xa;&#xd;&#xa;        // Busca a imagem na sua pasta de &#xed;cones&#xd;&#xa;        java.net.URL imgURL = getClass().getResource(&quot;/icones/ImagemLogo.png&quot;);&#xd;&#xa;        if (imgURL != null) {&#xd;&#xa;            java.awt.Image img = new javax.swing.ImageIcon(imgURL).getImage();&#xd;&#xa;            &#xd;&#xa;            // Desenha a imagem obedecendo EXATAMENTE o tamanho que voc&#xea; definiu nas propriedades&#xd;&#xa;            g.drawImage(img, 0, 0, getWidth(), getHeight(), this);&#xd;&#xa;        }&#xd;&#xa;    }&#xd;&#xa;}"/>
